#!/usr/bin/make -f
%:
	dh $@

# Prebuilt jar: nothing to compile or test at package-build time.
override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	install -D -m0644 eventb-animate.jar \
	    debian/eventb-animate/usr/share/java/eventb-animate/eventb-animate.jar
	install -D -m0755 debian/eventb-animate.sh \
	    debian/eventb-animate/usr/bin/eventb-animate
