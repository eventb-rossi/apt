#!/usr/bin/make -f
%:
	dh $@

# Prebuilt Eclipse RCP distribution: only repackage it.
override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	mkdir -p debian/rodin/usr/lib/rodin
	tar --exclude=./debian --exclude=./.pc -cf - . \
	    | tar -C debian/rodin/usr/lib/rodin -xf -
	install -D -m0755 debian/rodin.wrapper debian/rodin/usr/bin/rodin
	install -D -m0644 icon.xpm debian/rodin/usr/share/pixmaps/rodin.xpm
	install -D -m0644 debian/rodin.desktop \
	    debian/rodin/usr/share/applications/rodin.desktop

# Normalize permissions: drop the execute bit from all files, then restore it
# for the Eclipse native launcher and any shell scripts (shared objects and
# data files stay 0644).
override_dh_fixperms:
	dh_fixperms
	find debian/rodin/usr/lib/rodin -type f -exec chmod 0644 {} +
	find debian/rodin/usr/lib/rodin -type f | while read -r f; do \
	    if head -c2 "$$f" 2>/dev/null | grep -q '#!'; then chmod 0755 "$$f"; continue; fi; \
	    case "$$(file -b "$$f")" in *ELF*executable*) chmod 0755 "$$f";; esac; \
	done

# Do not strip / compute library dependencies from the prebuilt binaries.
override_dh_strip:

override_dh_dwz:

override_dh_shlibdeps:

override_dh_makeshlibs:
