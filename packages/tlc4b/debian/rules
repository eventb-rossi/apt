#!/usr/bin/make -f
%:
	dh $@

# Prebuilt jars from Maven Central: nothing to compile or test here.
override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	mkdir -p debian/tlc4b/usr/share/java/tlc4b
	install -m0644 jars/*.jar debian/tlc4b/usr/share/java/tlc4b/
	install -D -m0755 debian/tlc4b.sh debian/tlc4b/usr/bin/tlc4b
